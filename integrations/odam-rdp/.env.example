# =============================================================================
# Odam RDP → Veza OAA Integration — Environment Template
# Copy this file to .env and fill in real values.
# chmod 600 .env
# =============================================================================

# -----------------------------------------------------------------------------
# Source Data Configuration
# -----------------------------------------------------------------------------
# Path to the directory containing CrowdStrike RDP CSV export(s).
# If not set, the script defaults to the 'samples/' subdirectory.
# DATA_DIR=/opt/odam-rdp-veza/scripts/data

# Optionally point to a single CSV file instead of a directory:
# CSV_FILE=/opt/odam-rdp-veza/scripts/data/Odam-CrowdStrike-OAA.csv

# -----------------------------------------------------------------------------
# Veza Configuration
# -----------------------------------------------------------------------------
VEZA_URL=https://your-tenant.veza.com
VEZA_API_KEY=your_veza_api_key_here

# -----------------------------------------------------------------------------
# OAA Provider Settings (optional — override the script defaults)
# -----------------------------------------------------------------------------
# PROVIDER_NAME=Odam RDP
# DATASOURCE_NAME=CrowdStrike RDP Sessions
